SUPABASE_URL=
SUPABASE_KEY=               # use the service_role key (not the anon/publishable key)
SUPABASE_BUCKET=book-outputs

GEMINI_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=                  # for Gmail: use an App Password (16 chars, no spaces)
EMAIL_FROM=you@gmail.com
DEFAULT_FROM_NAME=BookBot

# How often (seconds) the polling loop checks for pending requests
POLL_INTERVAL_SECONDS=60
